hhhhh
Table Propietario {
  id_propietario int [pk, increment]
  nombre varchar
  telefono varchar
  direccion varchar
}

Table Embarcacion {
  id_embarcacion int [pk, increment]
  nombre varchar
  longitud_pies int
  estado varchar
  id_propietario int [ref: > Propietario.id_propietario]
}

Table Cliente {
  id_cliente int [pk, increment]
  nombre varchar
  telefono varchar
  direccion varchar
  experiencia_nivel varchar
}

Table Viaje {
  id_viaje int [pk, increment]
  fecha_inicio date
  fecha_fin date
  destino varchar
  nivel_peligro varchar
  id_cliente int [ref: > Cliente.id_cliente]
  id_embarcacion int [ref: > Embarcacion.id_embarcacion]
}

Table Equipo {
  id_equipo int [pk, increment]
  nombre varchar
  tipo varchar
  descripcion varchar
}

Table Equipo_Embarcacion {
  id_equipo_embarcacion int [pk, increment]
  id_embarcacion int [ref: > Embarcacion.id_embarcacion]
  id_equipo int [ref: > Equipo.id_equipo]
  cantidad int
}

Table Tripulacion {
  id_tripulacion int [pk, increment]
  nombre varchar
  especialidad varchar
  tarifa_hora decimal
}

Table Viaje_Tripulacion {
  id_viaje_tripulacion int [pk, increment]
  id_viaje int [ref: > Viaje.id_viaje]
  id_tripulacion int [ref: > Tripulacion.id_tripulacion]
  horas_trabajadas int
}

Table Mantenimiento {
  id_mantenimiento int [pk, increment]
  id_embarcacion int [ref: > Embarcacion.id_embarcacion]
  fecha date
  tipo_servicio varchar
  costo decimal
  descripcion varchar
}

Table Reparacion {
  id_reparacion int [pk, increment]
  id_embarcacion int [ref: > Embarcacion.id_embarcacion]
  fecha date
  descripcion varchar
  costo decimal
  calidad varchar
}

Table Despachador {
  id_despachador int [pk, increment]
  nombre varchar
  telefono varchar
}

Table Reparacion_Viaje {
  id_reparacion_viaje int [pk, increment]
  id_viaje int [ref: > Viaje.id_viaje]
  id_reparacion int [ref: > Reparacion.id_reparacion]
  id_despachador int [ref: > Despachador.id_despachador]
}